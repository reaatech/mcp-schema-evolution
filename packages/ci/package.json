{
  "name": "@mcp-schema-evolution/ci",
  "version": "0.0.0",
  "description": "CI/CD integrations for MCP schema evolution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-evolution-ci": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "schema",
    "evolution",
    "ci",
    "json-schema",
    "backward-compatibility",
    "github-actions",
    "model-context-protocol"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/mcp-schema-evolution.git",
    "directory": "packages/ci"
  },
  "bugs": {
    "url": "https://github.com/reaatech/mcp-schema-evolution/issues"
  },
  "homepage": "https://github.com/reaatech/mcp-schema-evolution#readme",
  "dependencies": {
    "@mcp-schema-evolution/core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
