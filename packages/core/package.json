{
  "name": "@reaatech/mcp-schema-evolution",
  "version": "0.0.0",
  "description": "Schema diffing, wrapper generation, deprecation, and changelog",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/mcp-schema-evolution.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/reaatech/mcp-schema-evolution#readme",
  "bugs": {
    "url": "https://github.com/reaatech/mcp-schema-evolution/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "schema",
    "evolution",
    "json-schema",
    "diff",
    "backward-compatibility",
    "model-context-protocol"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-check": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
