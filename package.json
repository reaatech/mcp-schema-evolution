{
  "name": "mcp-schema-evolution",
  "version": "0.0.0",
  "private": true,
  "description": "Tooling for safely evolving MCP tool schemas over time",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "schema",
    "evolution",
    "json-schema",
    "backward-compatibility",
    "model-context-protocol"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/mcp-schema-evolution.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/mcp-schema-evolution/issues"
  },
  "homepage": "https://github.com/reaatech/mcp-schema-evolution#readme",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@8.15.0"
}
